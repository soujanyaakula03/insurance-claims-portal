# ─── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=claims_db

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production

# ─── Service Ports ─────────────────────────────────────────────────
API_GATEWAY_PORT=3000
CLAIMS_SERVICE_PORT=3001
USERS_SERVICE_PORT=3002

# ─── Service Internal URLs (used by gateway) ───────────────────────
CLAIMS_SERVICE_URL=http://localhost:3001
USERS_SERVICE_URL=http://localhost:3002

# ─── Frontend ──────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
